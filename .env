# =========================================================
# 층간소음 예방 알림 시스템 환경변수 예시 파일
# 실제 사용 시 이 파일을 복사해서 .env 로 이름을 바꾼 뒤 사용하세요.
#
# cp .env.example .env
# =========================================================


# =========================================================
# 1. Discord / AI 알림 설정
# =========================================================

# Discord Webhook URL
# 실제 알림을 받을 Discord 채널의 Webhook URL을 넣습니다.
# GitHub에 실제 URL을 올리면 안 됩니다.
DISCORD_WEBHOOK_URL=

# Gemini API Key
# USE_AI_MESSAGE=1 일 때만 필요합니다.
# 실사용 안정성을 위해 기본적으로 AI 문구 생성을 끄는 것을 추천합니다.
GEMINI_API_KEY=

# AI 문구 생성 사용 여부
# 1 = Gemini를 사용해서 알림 문구 생성
# 0 = 기본 알림 문구 사용
USE_AI_MESSAGE=0

# Gemini 모델 이름
GEMINI_MODEL_NAME=gemini-2.5-flash

# 같은 종류의 알림을 다시 보내기까지 기다리는 시간, 초 단위
# 600초 = 10분
ALERT_COOLDOWN_SEC=600


# =========================================================
# 2. Debug / Log / Plot 설정
# =========================================================

# 상세 디버그 출력 여부
# 1 = 샘플 배열, 처리시간, 기준 초과 없음 등 상세 출력
# 0 = 상세 출력 끄기
DEBUG=0

# 측정값 로그 출력 여부
# DEBUG=0이어도 moment, Leq 같은 핵심 측정값은 남기고 싶을 때 사용
# 1 = 측정값 로그 출력
# 0 = 측정값 로그 출력 안 함
MEASURE_LOG_ENABLED=1

# 측정값 로그 출력 간격, 초 단위
MEASURE_LOG_INTERVAL_SEC=1

# FFT 그래프 저장 여부
# 1 = 주기적으로 그래프 저장 (진동 : 10프레임 단위 / 소리 : 100프레임 단위) 
# 0 = 기준치 초과시만 그래프 저장
PLOT_ENABLED=0

# 고체음 FFT 그래프 저장 주기
SOLID_PLOT_INTERVAL=10

# 공기전달 소음 FFT 그래프 저장 주기
SOUND_PLOT_INTERVAL=100

# FFT 그래프 저장 파일명
SOLID_PLOT_PATH=fft_result_solid.png
SOUND_PLOT_PATH=fft_result_sound.png


# =========================================================
# 3. 소음 기준치 설정
# =========================================================

# 공기전달 소음 Leq 기준 dB(A)
DAYTIME_AIR_LEQ=45
NIGHTTIME_AIR_LEQ=40

# 고체전달 충격음 기준 dB(A)
# LMAX = 순간 최대 소음도 기준
# LEQ  = 등가소음도 기준
DAYTIME_SOLID_LMAX=57
DAYTIME_SOLID_LEQ=43
NIGHTTIME_SOLID_LMAX=52
NIGHTTIME_SOLID_LEQ=38


# =========================================================
# 4. 고체음 센서 설정
# =========================================================

# Arduino / 진동센서 시리얼 포트
# 환경에 따라 /dev/ttyACM0 또는 /dev/ttyUSB0 등이 될 수 있습니다.
SOLID_SERIAL_PORT=/dev/ttyACM0

# Arduino Serial.begin() 값과 동일해야 합니다.
SOLID_BAUD_RATE=230400

# 시리얼 통신 timeout
SOLID_TIMEOUT=1.0

# 한 번에 읽을 byte 수
# 기존 Arduino 전송 구조 기준: 64개 short = 128 byte
SOLID_CHUNK_BYTES=128

# FFT 한 프레임 샘플 수
SOLID_FRAME_SIZE=1024

# 고체음 센서 샘플링 주파수
SOLID_SAMPLE_RATE_HZ=1600

# 초기 영점 offset
SOLID_INITIAL_OFFSET=256.0

# EMA 영점 보정 가중치
SOLID_OFFSET_ALPHA=0.01

# 센서 raw 값 1당 g 변환값
SOLID_G_PER_LSB=0.0039

# 중력가속도
GRAVITY=9.80665

# 이 값 이하의 가속도는 노이즈로 보고 제외
SOLID_ACC_CUTOFF=0.08

# 가속도 dB 변환 기준값
SOLID_ACC_REFERENCE=1e-5

# 고체음 Leq 계산에 사용할 최근 moment 개수
SOLID_LEQ_WINDOW_SIZE=100


# =========================================================
# 5. 공기전달 소음 센서 설정
# =========================================================

# 마이크 샘플링 주파수
SOUND_SAMPLE_RATE_HZ=44100

# FFT 한 프레임 샘플 수
SOUND_FRAME_SIZE=1024

# 마이크 채널 수
SOUND_CHANNELS=1

# 사용할 오디오 장치 번호
# 비워두면 기본 장치를 사용합니다.
# 예: SOUND_DEVICE=0
SOUND_DEVICE=

# int16 오디오 최대값 기준
SOUND_INT16_MAX=32768.0

# dBFS 값을 dB SPL처럼 보정하기 위한 offset
# 실제 소음계와 맞추려면 보정이 필요할 수 있습니다.
SOUND_SPL_OFFSET=100.0

# 공기전달 소음 Leq 계산에 사용할 최근 moment 개수
SOUND_LEQ_WINDOW_SIZE=13040


# =========================================================
# 6. 음향 계산 상수
# =========================================================

# 단위면적당 질량 kg/m^2
MASS_PER_UNIT_AREA=504

# 바닥 두께 m
FLOOR_THICKNESS=0.21

# 고체음 감쇠 상수
ALPHA=0.03

# 음향 방사율
SIGMA=1.0

# 진동 구조체 면적 m^2
SURFACE_AREA=10.0

# 실내 총 흡음력 m^2
ABSORPTION=10.0
