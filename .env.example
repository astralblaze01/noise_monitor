# =========================================================
# 층간소음 예방 알림 시스템 환경변수 예시 파일
# 실제 사용 시 이 파일을 복사해서 .env 로 이름을 바꾼 뒤 사용하세요.
#
# cp .env.example .env
# =========================================================


# =========================================================
# 1. Discord / AI 알림 설정
# =========================================================

# Discord Webhook URL
# 실제 알림을 받을 Discord 채널의 Webhook URL을 넣습니다.
# GitHub에 실제 URL을 올리면 안 됩니다.
DISCORD_WEBHOOK_URL=

# Gemini API Key
# USE_AI_MESSAGE=1 일 때만 필요합니다.
# 실사용 안정성을 위해 기본적으로 AI 문구 생성을 끄는 것을 추천합니다.
GEMINI_API_KEY=

# AI 문구 생성 사용 여부
# 1 = Gemini를 사용해서 알림 문구 생성
# 0 = 기본 알림 문구 사용
USE_AI_MESSAGE=0

# Gemini 모델 이름
GEMINI_MODEL_NAME=gemini-2.5-flash

# 같은 종류의 알림을 다시 보내기까지 기다리는 시간, 초 단위
# 600초 = 10분
ALERT_COOLDOWN_SEC=600


# =========================================================
# 2. Debug / Log / Plot 설정
# =========================================================

# 상세 디버그 출력 여부
# 1 = 샘플 배열, 처리시간, 기준 초과 없음 등 상세 출력
# 0 = 상세 출력 끄기
DEBUG=0

# 측정값 로그 출력 여부
# DEBUG=0이어도 moment, Leq 같은 핵심 측정값은 남기고 싶을 때 사용
# 1 = 측정값 로그 출력
# 0 = 측정값 로그 출력 안 함
MEASURE_LOG_ENABLED=1

# FFT 그래프 저장 여부
# 1 = 그래프 저장
# 0 = 그래프 저장 안 함
# 1 = 주기적으로 그래프 저장 (진동 : 10프레임 단위 / 소리 : 100프레임 단위) 
# 0 = 기준치 초과시만 그래프 저장
PLOT_ENABLED=0
